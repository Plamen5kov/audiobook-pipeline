# Audiobook Pipeline — Environment Variables
# Copy to .env and adjust as needed.

# ── Logging ────────────────────────────────────────────────────
# Log level for all Python services (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── Ollama ─────────────────────────────────────────────────────
# Timeout in seconds for LLM calls to Ollama (text-analyzer)
OLLAMA_TIMEOUT_S=300

# ── TTS ────────────────────────────────────────────────────────
# Max parallel TTS synthesis calls in the orchestrator
TTS_CONCURRENCY=3
