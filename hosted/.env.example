# URL of the DGX file-server, reached through the router port-forward
DGX_URL=http://jarvis-router.viliev.org:8080

# Timeout for DGX requests in milliseconds (0 = no timeout, useful for LLM calls)
DGX_TIMEOUT_MS=0

# Allowed CORS origin (default: * for dev, set to frontend URL in production)
CORS_ORIGIN=*

# Port the NestJS backend listens on (host-side)
BACKEND_PORT=3000

# Port the React frontend (nginx) listens on (host-side)
FRONTEND_PORT=4000
